generator client {
  provider     = "prisma-client"
  output       = "../lib/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            BigInt   @id @default(autoincrement())
  name          String   @db.VarChar(180)
  slug          String   @unique @db.VarChar(180)
  description   String
  price         Decimal  @db.Decimal(12, 2)
  oldPrice      Decimal? @map("old_price") @db.Decimal(12, 2)
  categoryId    Int      @map("category_id")
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  image         String
  galleryImages String[] @default([]) @map("gallery_images")
  unit          String   @default("adet") @db.VarChar(40)
  featured      Boolean  @default(false)
  inStock       Boolean  @default(true) @map("in_stock")
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive, featured, sortOrder])
  @@index([categoryId, sortOrder])
  @@map("products")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(100)
  slug      String    @unique @db.VarChar(120)
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive, sortOrder])
  @@map("categories")
}

model Admin {
  id           String    @id @default(cuid())
  username     String    @unique @db.VarChar(80)
  email        String    @unique @db.VarChar(190)
  name         String    @db.VarChar(120)
  passwordHash String    @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("admins")
}
